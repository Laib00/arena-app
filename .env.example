# Copy this file to .env for local development with `vercel dev` or `npm run dev`.
# In production (Vercel dashboard), set these under Project Settings > Environment Variables.
# Never commit your actual .env file.

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
